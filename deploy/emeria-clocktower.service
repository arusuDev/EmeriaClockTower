[Unit]
Description=Emeria Clock Tower Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/EmeriaClockTower
EnvironmentFile=-/home/ubuntu/EmeriaClockTower/.env
ExecStart=/home/ubuntu/EmeriaClockTower/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
