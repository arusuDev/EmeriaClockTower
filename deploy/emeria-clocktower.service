[Unit]
Description=Emeria Clock Tower Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/EmeriaClockTower
EnvironmentFile=/opt/EmeriaClockTower/.env
ExecStart=/opt/EmeriaClockTower/.venv/bin/python bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
